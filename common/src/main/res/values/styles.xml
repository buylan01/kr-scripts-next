<resources>
    <style name="SceneSeekbarIcon">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:alpha">0.45</item>
        <item name="android:background">@drawable/seekbar_progress_icon</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">4dp</item>
        <item name="android:scaleType">centerInside</item>
    </style>

    <style name="textTitle" parent="@style/TextAppearance.AppCompat.Title">
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">14dp</item>
        <item name="android:alpha">0.8</item>
    </style>

    <style name="textSmallTitle" parent="textTitle">
        <item name="android:textSize">11dp</item>
    </style>

    <style name="textDefault">
        <item name="android:textColor">?android:attr/textColorPrimary</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">14dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="textSmall">
        <item name="android:textColor">?android:attr/textColorSecondary</item>
        <item name="android:textSize">11dp</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="textSecondary">
        <item name="android:textColor">?android:attr/textColorSecondary</item>
        <item name="android:textSize">11dp</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:alpha">0.5</item>
    </style>

    <style name="dialogLargeBtn" parent="@style/Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
    </style>
    <style name="dialogConfirmBtn" parent="dialogLargeBtn">
        <item name="android:textColor">#ffffff</item>
    </style>

    <style name="dialogCancelBtn" parent="dialogLargeBtn">
        <item name="android:layout_marginStart">0dp</item>
    </style>

    <style name="dialogRoot">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="dialogTitle" parent="@style/textTitle">
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">16dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="dialogDesc" parent="@style/textSmall">
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="dialogWarn" parent="@style/textSmall">
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:layout_marginTop">16dp</item>
        <item name="android:background">@drawable/in_card_item_inactive</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
    </style>

    <style name="dialog_full_screen" parent="Theme.AppCompat.Dialog">
        <!--<item name="android:windowNoTitle">true</item>-->
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Translucent</item>
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:fitsSystemWindows">false</item>
        <!-- 浮于Activity之上 -->
        <item name="android:windowIsFloating">false</item>
        <!-- 边框 -->
        <item name="android:windowFrame">@null</item>
        <item name="android:windowCloseOnTouchOutside">false</item>
    </style>

    <style name="dialog_full_screen_light" parent="@style/dialog_full_screen">
        <item name="android:windowBackground">@android:color/background_light</item>
        <item name="android:statusBarColor">@android:color/background_light</item>
    </style>

    <style name="dialog_full_screen_dark" parent="@style/dialog_full_screen">
        <item name="android:windowBackground">@android:color/background_dark</item>
        <item name="android:statusBarColor">@android:color/background_dark</item>
    </style>
</resources>
