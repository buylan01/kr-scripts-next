<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/dialogRoot"
    android:clickable="true"
    android:focusable="true">

    <ImageButton
        android:id="@+id/btn_hide"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:contentDescription="@null"
        android:scaleType="centerInside"
        android:padding="8dp"
        android:background="@null"
        android:src="@drawable/baseline_keyboard_arrow_down_24"
        app:tint="?colorOnSurface" />

    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_alignParentStart="true"
        android:layout_toStartOf="@id/btn_hide"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/title"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:paddingTop="0dp"
            style="@style/dialogTitle" />

        <TextView
            android:id="@+id/desc"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:paddingTop="0dp"
            style="@style/dialogDesc" />
    </LinearLayout>

    <ScrollView
        android:layout_marginTop="16dp"
        android:background="@drawable/krscript_item_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottom_actions"
        android:layout_below="@+id/top_bar"
        android:layout_marginHorizontal="16dp">

        <TextView
            android:id="@+id/shell_output"
            android:breakStrategy="simple"
            android:textIsSelectable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:padding="12dp" />
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottom_actions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="end"
        android:layout_marginTop="16dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btn_copy"
            style="@style/dialogLargeBtn"
            android:text="@string/btn_copy_output" />

        <Button
            android:id="@+id/btn_exit"
            style="@style/dialogLargeBtn"
            android:text="@string/btn_exit" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/action_progress"
        android:layout_marginTop="12dp"
        android:layout_marginHorizontal="16dp"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_below="@+id/top_bar"
        android:indeterminate="true"
        android:max="100"
        android:progress="0" />
</RelativeLayout>